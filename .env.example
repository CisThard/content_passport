# ==============================================================================
# Content Passport Environment Variables Configuration Template (.env.example)
# ==============================================================================
# 복사하여 .env 또는 .env.local 파일을 생성한 뒤 실제 설정 값을 입력하세요.
# 보안 주의: 실제 키값이 포함된 .env 파일은 절대 Git 저장소에 커밋하지 마세요.
#
# ------------------------------------------------------------------------------
# 💡 [중요] 로컬 개발(Local) vs 클라우드 배포(GCP Cloud Run) 세팅 가이드
# ------------------------------------------------------------------------------
# 1. 로컬 개발 환경 (Local Development)
#    - 본 .env 파일의 값을 로컬 환경에 맞게 기입하여 로컬 서버 기동 시 적용합니다.
#    - AI 분석(K-9 Sniffer)은 'GOOGLE_GENERATIVE_AI_API_KEY'를 통해 Gemini API를 호출합니다.
#    - 메모리 데이터는 로컬 휘발성 메모리(InMemory) 또는 MemWal 릴레이어를 사용합니다.
#
# 2. 클라우드 배포 환경 (GCP Cloud Run - Production)
#    - 본 .env 파일은 클라우드로 업로드되지 않으며, 배포 시 모든 설정은 다음 경로를 통해 자동 주입됩니다:
#      A. GitHub Secrets: GCP WIF 연결 변수 (GCP_PROJECT_ID, WIF_PROVIDER 등)
#      B. GCP Secret Manager: 비밀키 보안 보관 (SUI_PRIVATE_KEY, MEMWAL_PRIVATE_KEY 등)
#      C. GitHub Actions: 일반 환경 변수 자동 주입 (.github/workflows/ci.yml의 env_vars)
#    - AI 분석은 API 키 노출 없이 GCP IAM 권한을 활용하여 Vertex AI(Gemini 3.5 Flash)를 호출합니다.
#    - 메모리 데이터는 GCP Cloud Firestore 데이터베이스를 활성화하여 영구 동기화합니다.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 사용자 인증 및 보안 설정 (Auth.js / NextAuth v5)
# ------------------------------------------------------------------------------
# 구글 로그인 연동을 위한 OAuth 클라이언트 정보 (Google Cloud Console에서 발급)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-your-google-client-secret"

# NextAuth 세션 암호화 및 토큰 해싱을 위한 난수 보안키
# (생성 방법: 터미널에서 'openssl rand -base64 33' 실행)
AUTH_SECRET="your-nextauth-session-secret-key"

# zkLogin salt-service master seed
# - 권장: 사용자별 salt를 HKDF(seed, iss/aud/sub)로 안정적으로 파생합니다.
# - 생성 방법: openssl rand -hex 32
# - 이 값이 바뀌면 기존 zkLogin 주소 접근성이 바뀌므로 Testnet/Mainnet별로 안전하게 백업하세요.
ZKLOGIN_SALT_MASTER_SEED="replace-with-stable-private-hex-seed"

# Legacy/testnet-only fallback. 가능하면 위 ZKLOGIN_SALT_MASTER_SEED를 사용하세요.
# ZKLOGIN_USER_SALT="123456789"

# API 서버가 기동되는 기본 서비스 주소 (Canonical URL)
# - 로컬 테스트: http://localhost:3000
# - 실서버 배포: https://content-passport.xyz
AUTH_URL="http://localhost:3000"


# ------------------------------------------------------------------------------
# 2. Sui 블록체인 연동 설정 (Sui Blockchain Integration)
# ------------------------------------------------------------------------------
# Sui 스마트 계약 패키지 ID (수이 테스트넷/메인넷에 게시된 트랜잭션 주소)
CONTENT_RIGHT_PACKAGE_ID="0xac28432a557d52d7079930a82a5c1732a3709da3c6cb2991ce0332b0704061da"

# 수이 트랜잭션 가스비 지불 및 승인을 담당하는 블록체인 운영자 개인키
# - 로컬 개발: 아래에 키를 입력하여 테스트합니다.
# - GCP Cloud Run: Secret Manager에 'SUI_PRIVATE_KEY'란 이름으로 등록하여 주입합니다.
SUI_PRIVATE_KEY="suiprivkey1..."

# 네트워크 환경 구분 (testnet | mainnet)
SUI_NETWORK="testnet"


# ------------------------------------------------------------------------------
# 3. Walrus 분산 데이터 저장소 (Walrus Protocol HTTP API)
# ------------------------------------------------------------------------------
# 미디어를 블롭 데이터로 업로드/저장하기 위한 Walrus 퍼블리셔 API 엔드포인트
WALRUS_PUBLISHER="https://publisher.walrus-testnet.walrus.space"

# 저장된 블롭 데이터 및 паспорта를 조회하기 위한 Walrus 어그리게이터 API 엔드포인트
WALRUS_AGGREGATOR="https://aggregator.walrus-testnet.walrus.space"


# ------------------------------------------------------------------------------
# 4. Walrus Memory Ledger (MemWal) & GCP 데이터베이스 연동
# ------------------------------------------------------------------------------
# MemWal 리레이어 허브 서버 주소
MEMWAL_SERVER_URL="https://relayer.memory.walrus.xyz"

# 포렌식 단서 및 에이전트 분석 내역이 기록될 스토리지 네임스페이스
MEMWAL_NAMESPACE="content-right-hackathon"

# 온체인 MemWal 계정 레지스트리 고유 식별자 ID
MEMWAL_ACCOUNT_ID="0xd9e5de22603fa7d327f2debdd91830cdeeb60799e36ab70fc1a37532cdfdd67e"

# 온체인 단서 기록 위임을 위해 브라우저 또는 CLI에서 발급받은 델리게이트 비밀키
# (로컬 로그인 시 `npm run memwal:login` 명령어를 통해 자동으로 획득 가능)
# *주의*: Sui 및 MemWal 개인키 파싱 시, Base64/Sui 스키마 플래그가 포함되어 맨 앞바이트가 0인 33바이트의 키가 전달되면
#         src/memwal.ts에서 자동으로 첫 바이트(00)를 스트리핑하여 32바이트로 정상 해독해냅니다.
MEMWAL_PRIVATE_KEY="8e3b99..."

# 온체인 기록을 연계할 MemWal 스마트 계약 패키지 ID
MEMWAL_PACKAGE_ID="0x..."

# 온체인 기록을 연계할 MemWal 레지스트리 Object ID
MEMWAL_REGISTRY_ID="0x..."

# 위임된 델리게이트의 공개키 식별값
MEMWAL_DELEGATE_PUBLIC_KEY="0x..."

# 델리게이트 식별을 위한 레이블 이름
MEMWAL_DELEGATE_LABEL="ContentRightHackathon"

# GCP Cloud Firestore 데이터베이스 활성화 및 연동 (GCP 환경 전용)
# - 로컬 개발: "false"로 두면 메모리(InMemory) 캐시를 사용합니다.
# - GCP Cloud Run: "true"로 설정하고 GCP_PROJECT_ID를 명시하면 Firestore 데이터베이스에 에이전트 검증 정보가 영구 적재됩니다.
GCP_FIRESTORE_ENABLED="false"
GCP_PROJECT_ID="project-71ed5c01-e218-4969-862"
GCP_REGION="asia-northeast3"


# ------------------------------------------------------------------------------
# 5. 구글 제미나이 AI 포렌식 설정 (Gemini & Vertex AI Cognitive Sniffer)
# ------------------------------------------------------------------------------
# K-9 Sniffer 에이전트가 인공지능 이미지 분석 및 조작 여부 감지에 활용하는 Gemini API 키
# - 로컬 개발: 이 키 값을 활성화하여 분석에 사용합니다.
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSy..."

# GCP 환경에서 패스워드나 API 키 없이 IAM 권한으로 Vertex AI를 사용할지 여부
# - 로컬 개발: "false"로 설정하여 API 키 방식을 유지합니다.
# - GCP Cloud Run: "true"로 설정하면 Cloud Run 서비스 계정의 IAM 권한을 빌려 API 키 없이 안전하게 Gemini 3.5 모델을 호출합니다.
GCP_VERTEX_AI_ENABLED="false"


# ------------------------------------------------------------------------------
# 6. 안드로이드 모바일 앱 서명 설정 (Android App Release Signing)
# ------------------------------------------------------------------------------
# 릴리즈용 모바일 빌드 apk/bundle 서명을 위한 파일 경로 또는 keystore 데이터
ANDROID_SIGNING_KEY="/path/to/content-passport-release.jks"

# 키스토어 생성 시 설정했던 고유 별칭 (Alias)
ANDROID_ALIAS="content-passport"

# 키스토어 전체 보안 비밀번호
ANDROID_KEYSTORE_PASSWORD="keystore-master-password"

# 별칭(Alias)에 할당된 서명 비밀번호
ANDROID_KEY_PASSWORD="alias-signature-password"


SUI_SPONSOR_SECRET_KEY=""