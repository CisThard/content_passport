{
  "name": "content-right",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run",
    "demo": "tsx src/demo.ts",
    "memwal": "tsx --env-file=.env scripts/memwal.ts",
    "memwal:login": "tsx --env-file=.env scripts/memwal.ts login",
    "memwal:health": "tsx --env-file=.env scripts/memwal.ts health",
    "memwal:remember": "tsx --env-file=.env scripts/memwal.ts remember",
    "memwal:recall": "tsx --env-file=.env scripts/memwal.ts recall",
    "memwal:restore": "tsx --env-file=.env scripts/memwal.ts restore",
    "memwal:delegate": "tsx --env-file=.env scripts/memwal.ts delegate",
    "memwal:create-account": "tsx --env-file=.env scripts/memwal.ts create-account",
    "memwal:add-delegate": "tsx --env-file=.env scripts/memwal.ts add-delegate",
    "start": "tsx --env-file=.env src/server.ts"
