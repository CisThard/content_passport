    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.1",
    "tsx": "^4.20.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "c2pa-node": "^0.5.26"
  }
